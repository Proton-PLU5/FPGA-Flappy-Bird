entity LivesRenderer is
    port (
        clk : in std_logic;
        pixel_row    : in std_logic_vector(9 downto 0);
        pixel_column : in std_logic_vector(9 downto 0);
        collision_check : in std_logic;
        red   : out std_logic_vector(3 downto 0);
        green : out std_logic_vector(3 downto 0);
        blue  : out std_logic_vector(3 downto 0);
        enabled : out std_logic;
        no_lives_left : out std_logic
    );
end entity;

architecture behavior of LivesRenderer is

    component SpriteRenderer is
        port (
            clk : in std_logic;
            pixel_row    : in std_logic_vector(9 downto 0);
            pixel_column : in std_logic_vector(9 downto 0);
            start_x  : in std_logic_vector(9 downto 0);
            start_y  : in std_logic_vector(9 downto 0);
            sprite_id : in integer;
            red   : out std_logic_vector(3 downto 0);
            green : out std_logic_vector(3 downto 0);
            blue  : out std_logic_vector(3 downto 0);
            transparent : out std_logic
        );
    end component;

    signal start_x1 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(10, 10); 
    signal start_y1 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(10, 10);
    signal sprite_id1 : integer := 3;
    signal transparent1 : std_logic;

    signal start_x2 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(50, 10);
    signal start_y2 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(10, 10);
    signal sprite_id2 : integer := 3;
    signal transparent2 : std_logic;
    
    signal start_x3 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(90, 10);
    signal start_y3 : std_logic_vector(9 downto 0) := CONV_STD_LOGIC_VECTOR(10, 10);
    signal sprite_id3 : integer := 3;
    signal transparent3 : std_logic;

    signal lost_life1 : std_logic := '0';
    signal lost_life2 : std_logic := '0';
    signal lost_life3 : std_logic := '0';

    signal render : std_logic;

begin

    LIFE1_COMPONENT : SpriteRenderer port map (
        clk => clk,
        pixel_row => pixel_row,
        pixel_column => pixel_column,
        start_x => start_x1,
        start_y => start_y1,
        sprite_id => 3,
        red => red,
        green => green,
        blue => blue,
        transparent => transparent
    );

    LIFE2_COMPONENT : SpriteRenderer port map (
        clk => clk,
        pixel_row => pixel_row,
        pixel_column => pixel_column,
        start_x => start_x2,
        start_y => start_y2,
        sprite_id => 3,
        red => red,
        green => green,
        blue => blue,
        transparent => transparent
    );
    
    LIFE3_COMPONENT : SpriteRenderer port map (
        clk => clk,
        pixel_row => pixel_row,
        pixel_column => pixel_column,
        start_x => start_x3,
        start_y => start_y3,
        sprite_id => 3,
        red => red,
        green => green,
        blue => blue,
        transparent => transparent
    );

    render <= '1' when (('0' & pixel_column >= '0' & start_x1) and ('0' & pixel_column < '0' & start_x1 + CONV_STD_LOGIC_VECTOR(16,10))); or 
                    (('0' & pixel_column >= '0' & start_x2) and ('0' & pixel_column < '0' & start_x2 + CONV_STD_LOGIC_VECTOR(16,10))); or 
                    (('0' & pixel_column >= '0' & start_x3) and ('0' & pixel_column < '0' & start_x3 + CONV_STD_LOGIC_VECTOR(16,10)))	
                else '0';   

    COLLISION: process(clk)
    begin 
        if (collision_check = '1') then
            if (life_lost1 = '0') then
                sprite_id1 <= 4; -- change to empty heart
                life_lost1 <= '1';
            elsif (life_lost2 = '0' and life_lost1 = '1') then
                sprite_id2 <= 4; 
                life_lost2 <= '1';
            elsif (life_lost3 = '0' and life_lost2 = '1') then
                sprite_id3 <= 4; 
                life_lost3 <= '1';
            else (life_lost1 = '1' and life_lost2 = '1' and life_lost3 = '1') then
                no_lives_left <= '1';
            end if;
        end if;
    end process;

    enabled <= render and not transparent1 and not transparent2 and not transparent3;

end architecture;